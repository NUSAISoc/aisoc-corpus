---
import BaseLayout from "../layouts/BaseLayout.astro";
import CategoryNav from "../components/CategoryNav.astro";
import KnowledgeGraph from "../components/KnowledgeGraph.tsx";
import { websiteSchema } from "../lib/seo";
---

<BaseLayout
  title="Home"
  description="Explore AI and machine learning concepts through the NUS AI Society interconnected knowledge graph."
  canonicalPath="/"
  jsonLd={websiteSchema()}
>
  <section class="hero-intro">
    <h1>The Corpus</h1>
    <p class="intro-text">
      An interconnected knowledge graph mapping the landscape of artificial
      intelligence. Each node is a concept. Each edge is a
      relationship&mdash;either a learning prerequisite or a semantic similarity
      computed via Jaccard index over shared tags. Drag, zoom, and click to
      explore how ideas connect.
    </p>
  </section>

  <div class="home-category-nav">
    <CategoryNav />
  </div>

  <section class="graph-section">
    <KnowledgeGraph client:load />
  </section>
</BaseLayout>

<style>
  .hero-intro {
    text-align: center;
    margin-bottom: 2rem;
  }

  .hero-intro h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    background: linear-gradient(135deg, #ccff00 0%, #6366f1 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 0.75rem;
  }

  .intro-text {
    max-width: 640px;
    margin: 0 auto;
    color: var(--color-muted);
    font-size: 0.9rem;
    line-height: 1.7;
  }

  .home-category-nav {
    margin-bottom: 2rem;
  }

  .graph-section {
    min-height: 500px;
  }
</style>
