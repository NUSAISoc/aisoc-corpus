---
import { getCollection, type CollectionEntry } from "astro:content";
import CategoryNav from "../../components/CategoryNav.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { CATEGORY_LABELS } from "../../lib/categories";
import { breadcrumbSchema } from "../../lib/seo";
import { topicSlugFromId } from "../../lib/topic-slugs";

type Topic = CollectionEntry<"topics">;

const topics = (await getCollection("topics")).sort((a: Topic, b: Topic) =>
  a.data.title.localeCompare(b.data.title),
);

const normalizeSearchText = (value: string) => value.toLowerCase().trim();

const searchIndex = topics.map((topic: Topic) => {
  const categoryLabel = CATEGORY_LABELS[topic.data.category];
  const searchableParts = [
    topic.data.title,
    topic.data.description,
    topic.data.author,
    topic.data.difficulty,
    topic.data.category,
    categoryLabel,
    ...topic.data.domains,
    ...topic.data.tags,
  ];

  return {
    id: topicSlugFromId(topic.id),
    title: topic.data.title,
    haystack: normalizeSearchText(searchableParts.join(" ")),
  };
});

const searchIndexJson = JSON.stringify(searchIndex).replace(/</g, "\\u003c");
---

<BaseLayout
  title="Topics"
  description="Browse AI Soc Corpus machine learning topics by title, tag, category, difficulty, and author."
  canonicalPath="/topics/"
  jsonLd={breadcrumbSchema([
    { name: "Home", path: "/" },
    { name: "Topics", path: "/topics/" },
  ])}
>
  <h1>Topics</h1>

  <section class="topic-categories">
    <CategoryNav ariaLabel="Browse topics by category" />
  </section>

  <section class="topic-search">
    <label for="topic-search-input">Search topics</label>
    <div class="topic-search__control">
      <input
        id="topic-search-input"
        type="search"
        placeholder="Search title, tag, category, author..."
        autocomplete="off"
      />
      <span id="topic-search-count" aria-live="polite"
        >{topics.length} shown</span
      >
    </div>
  </section>

  <div class="topic-grid">
    {
      topics.map((topic: Topic) => (
        <a
          href={`/topics/${topicSlugFromId(topic.id)}`}
          class="topic-card"
          data-topic-card
          data-topic-id={topicSlugFromId(topic.id)}
        >
          <div class="topic-card__meta">
            <span class="topic-difficulty" data-level={topic.data.difficulty}>
              {topic.data.difficulty}
            </span>
            <span class="topic-category">
              {CATEGORY_LABELS[topic.data.category]}
            </span>
          </div>
          <h3>{topic.data.title}</h3>
          <p>{topic.data.description}</p>
          <span class="topic-author">@{topic.data.author}</span>
        </a>
      ))
    }
  </div>
  <p class="topic-empty" hidden>No topics match this search.</p>
  <script
    is:inline
    type="application/json"
    id="topic-search-index"
    set:html={searchIndexJson}
  />
  <script is:inline>
    const input = document.querySelector("#topic-search-input");
    const count = document.querySelector("#topic-search-count");
    const empty = document.querySelector(".topic-empty");
    const indexEl = document.querySelector("#topic-search-index");
    const cards = new Map(
      Array.from(document.querySelectorAll("[data-topic-card]")).map((card) => [
        card.dataset.topicId,
        card,
      ]),
    );
    const searchIndex = JSON.parse(indexEl?.textContent || "[]");

    function normalizeQuery(value) {
      return value.toLowerCase().trim().split(/\s+/).filter(Boolean);
    }

    function updateSearch() {
      const tokens = normalizeQuery(input.value);
      let visibleCount = 0;

      for (const entry of searchIndex) {
        const card = cards.get(entry.id);
        const isVisible =
          tokens.length === 0 ||
          tokens.every((token) => entry.haystack.includes(token));

        if (card) {
          card.hidden = !isVisible;
        }
        if (isVisible) {
          visibleCount += 1;
        }
      }

      count.textContent = `${visibleCount} shown`;
      empty.hidden = visibleCount !== 0;
    }

    input?.addEventListener("input", updateSearch);
  </script>
</BaseLayout>

<style>
  h1 {
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }

  .topic-count {
    color: var(--color-muted);
    margin-bottom: 1.5rem;
  }

  .topic-categories {
    margin-bottom: 1.5rem;
  }

  .topic-search {
    margin-bottom: 1.5rem;
  }

  .topic-search label {
    display: block;
    margin-bottom: 0.45rem;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-muted-strong);
  }

  .topic-search__control {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 0.75rem;
    align-items: center;
  }

  .topic-search input {
    width: 100%;
    min-height: 2.6rem;
    padding: 0.65rem 0.85rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 0;
    background: rgba(10, 10, 12, 0.65);
    color: var(--color-text);
    font: inherit;
    outline: none;
    transition:
      border-color 0.2s ease,
      box-shadow 0.2s ease;
  }

  .topic-search input:focus {
    border-color: rgba(204, 255, 0, 0.55);
    box-shadow: 0 0 0 3px rgba(204, 255, 0, 0.1);
  }

  .topic-search input::placeholder {
    color: rgba(161, 161, 170, 0.75);
  }

  #topic-search-count {
    color: var(--color-muted);
    font-size: 0.72rem;
    white-space: nowrap;
  }

  .topic-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }

  .topic-card {
    padding: 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: 0;
    background: var(--color-surface);
    transition:
      border-color 0.2s ease,
      box-shadow 0.2s ease;
  }

  .topic-card:hover {
    border-color: rgba(204, 255, 0, 0.4);
    box-shadow: 0 0 16px rgba(204, 255, 0, 0.1);
  }

  .topic-card__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    align-items: center;
  }

  .topic-card h3 {
    font-size: 1rem;
    margin: 0.5rem 0 0.4rem;
  }

  .topic-card p {
    font-size: 0.82rem;
    color: var(--color-muted);
    margin: 0;
  }

  .topic-author {
    display: inline-block;
    margin-top: 0.9rem;
    color: var(--color-muted-strong);
    font-size: 0.7rem;
  }

  .topic-empty {
    margin: 1.5rem 0 0;
    color: var(--color-muted);
    font-size: 0.85rem;
  }

  .topic-difficulty,
  .topic-category {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    padding: 0.2rem 0.5rem;
    border-radius: 0;
  }

  .topic-difficulty {
    background: rgba(204, 255, 0, 0.1);
    color: var(--color-accent);
  }

  .topic-difficulty[data-level="intermediate"] {
    background: rgba(99, 102, 241, 0.15);
    color: var(--color-accent-secondary);
  }

  .topic-difficulty[data-level="advanced"] {
    background: rgba(139, 92, 246, 0.15);
    color: var(--color-accent-tertiary);
  }

  .topic-category {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--color-border);
    color: var(--color-muted);
  }

  @media (max-width: 640px) {
    .topic-search__control {
      grid-template-columns: 1fr;
    }
  }
</style>
