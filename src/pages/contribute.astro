---
import BaseLayout from "../layouts/BaseLayout.astro";
import { breadcrumbSchema } from "../lib/seo";
---

<BaseLayout
  title="Contribute"
  description="Learn how to contribute AI and machine learning topic pages to the AI Soc Corpus through reviewed GitHub pull requests."
  canonicalPath="/contribute/"
  jsonLd={breadcrumbSchema([
    { name: "Home", path: "/" },
    { name: "Contribute", path: "/contribute/" },
  ])}
>
  <section class="contribute-page">
    <h1>Contribute</h1>
    <blockquote class="witty-quote">
      "If I have seen further, it is by standing on the shoulders of giants —
      and occasionally writing better documentation."
    </blockquote>

    <p>
      The AI Soc Corpus grows through collective intelligence. Every topic you
      contribute strengthens the graph and lights the path for the community in
      the future.
    </p>

    <h2>How It Works</h2>
    <p>
      Contributions are made via <strong>Git pull requests</strong>. This
      ensures every addition is peer-reviewed for accuracy, clarity, and
      academic rigour.
    </p>

    <ol>
      <li>Fork the repository on GitHub.</li>
      <li>
        Add a Markdown file to <code>src/content/topics/&lt;category&gt;/</code>
        (e.g. <code>deep-learning/</code>) with the required frontmatter.
      </li>
      <li>
        Use <code>[[WikiLinks]]</code> to connect your topic to related concepts.
      </li>
      <li>
        Run <code>./scripts/validate-content.sh</code> locally to check your work.
      </li>
      <li>Submit a pull request. CI verifies everything automatically.</li>
    </ol>

    <div class="cta-section">
      <a
        href="https://github.com/NUSAISoc/aisoc-corpus/blob/main/CONTRIBUTING.md"
        target="_blank"
        rel="noopener noreferrer"
        class="cta-btn"
      >
        Read the Full Contribution Guide on GitHub &rarr;
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .contribute-page {
    max-width: 680px;
    margin: 0 auto;
  }

  .contribute-page h1 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .witty-quote {
    border-left: 3px solid var(--color-accent);
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: var(--color-muted);
    font-style: italic;
    font-size: 0.95rem;
  }

  .contribute-page p {
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  .contribute-page ol {
    line-height: 2;
    padding-left: 1.2rem;
  }

  .contribute-page code {
    background: var(--color-surface);
    padding: 0.15em 0.4em;
    border-radius: 0;
    font-size: 0.85em;
  }

  .cta-section {
    margin-top: 2rem;
    text-align: center;
  }

  .cta-btn {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    font-size: 0.85rem;
    font-family: var(--font-body);
    color: var(--color-accent);
    border: 1px solid var(--color-accent);
    border-radius: 0;
    transition: all 0.2s ease;
  }

  .cta-btn:hover {
    background: rgba(204, 255, 0, 0.1);
    box-shadow: var(--shadow-glow);
  }
</style>
